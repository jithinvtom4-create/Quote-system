rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidQuote(data) {
      return data.id is string 
        && data.userId is string 
        && data.custName is string 
        && data.quoteRef is string 
        && data.status is string;
    }

    match /quotes/{quoteId} {
      allow read, write: if isValidQuote(request.resource.data || resource.data);
    }
    
    // Test collection for boot check
    match /test/connection {
      allow read: if true;
    }
  }
}
